@page "/performance"
@using Microsoft.Extensions.Logging
@using Soenneker.Blazor.DataTables.Demo.Dtos
@using Soenneker.Blazor.DataTables.Options

@inject ILogger<Index> Logger

<Div Space="Space.Y.Is6">
    <Div Space="Space.Y.Is2">
        <H1 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" Margin="Margin.Is0">DataTables performance</H1>
        <Paragraph Margin="Margin.Is0" TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm">
            Large client-side dataset (500 rows) for scroll and render stress.
        </Paragraph>
    </Div>

    <DemoPanel Title="Heavy table" Description="Same row shape as the home demo with more rows.">
        <Soenneker.Blazor.DataTables.DataTable Options="_options">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Position</th>
                    <th>Office</th>
                    <th>Age</th>
                    <th>Start date</th>
                    <th>Salary</th>
                    <th>Link</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Employee employee in _employees)
                {
                    <tr>
                        <td>@employee.Name</td>
                        <td>@employee.Position</td>
                        <td>@employee.City</td>
                        <td>@employee.Age</td>
                        <td>@employee.StartDate</td>
                        <td>@employee.Salary</td>
                        <td>
                            <Anchor To="/">Home</Anchor>
                        </td>
                    </tr>
                }
            </tbody>
        </Soenneker.Blazor.DataTables.DataTable>
    </DemoPanel>

    <DemoPanel Title="Navigation" Description="Return to the main demo.">
        <DemoButtonRow>
            <Button To="/" Variant="ButtonVariant.Outline">Back to home</Button>
        </DemoButtonRow>
    </DemoPanel>
</Div>

@code
{
    Options.DataTableOptions _options = null!;

    readonly List<Employee> _employees = [];

    protected override void OnInitialized()
    {
        for (var i = 0; i < 500; i++)
        {
            _employees.Add(new Employee { Name = "John Doe", Position = "Developer", City = "London", Age = 28, StartDate = DateTime.UtcNow, Salary = 320800 });
        }

        _options = new Options.DataTableOptions
        {
            Dom = "Bfrtip",
            Searching = true,
            LengthChange = false,
            Info = false,
            Paging = false,
            Order = [new object[] {0, "asc"}],
            OrderMulti = true
        };
    }
}
